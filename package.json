{
  "name": "ferred-app",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter renderer dev",
    "dev:server": "pnpm --filter server dev",
    "dev:renderer": "pnpm --filter renderer dev",
    "dev:electron": "wait-on http://localhost:5173 && wait-on http://localhost:3001/health && pnpm --filter @ferred/electron dev",
    "build": "pnpm build:server && pnpm build:renderer",
    "build:server": "pnpm --filter server build",
    "build:renderer": "pnpm --filter renderer build",
    "db:migrate": "cd apps/server && DATABASE_URL=\"file:../../data/ferred_branch1.db\" pnpm prisma:migrate",
    "db:generate": "cd apps/server && DATABASE_URL=\"file:../../data/ferred_branch1.db\" pnpm prisma:generate",
    "db:seed": "pnpm --filter server db:seed",
    "db:setup": "mkdir -p data && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0"
  }
}
